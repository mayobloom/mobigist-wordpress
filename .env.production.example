PROJECT_NAME=mobigist

WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=replace-with-strong-password
WORDPRESS_DB_ROOT_PASSWORD=replace-with-strong-root-password

WORDPRESS_URL=https://mobigist.com
WORDPRESS_TITLE=Mobigist
WORDPRESS_ADMIN_USER=replace-admin-user
WORDPRESS_ADMIN_PASSWORD=replace-with-strong-admin-password
WORDPRESS_ADMIN_EMAIL=replace-with-admin-email

WORDPRESS_DEBUG=0
WORDPRESS_ENV=production

AWS_SES_SMTP_HOST=email-smtp.ap-northeast-2.amazonaws.com
AWS_SES_SMTP_PORT=587
AWS_SES_SMTP_USER=replace-with-ses-smtp-user
AWS_SES_SMTP_PASSWORD=replace-with-ses-smtp-password
AWS_SES_FROM_EMAIL=replace-with-sender-email
AWS_SES_FROM_NAME=Mobigist

PKB_PRIVACY_OFFICER_NAME=replace-with-privacy-officer-name
PKB_PRIVACY_CONTACT_EMAIL=replace-with-privacy-contact-email
PKB_PRIVACY_CONTACT_DEPARTMENT=replace-with-privacy-contact-department
